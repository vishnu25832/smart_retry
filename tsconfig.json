{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "moduleResolution": "Node",

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "types": [
      "node",
      "jest"
    ]
  },

  "include": [
    "src/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}